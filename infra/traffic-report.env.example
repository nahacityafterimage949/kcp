# KCP Traffic Reporter — configuração
# Arquivo: /etc/kcp/traffic-report.env
# Permissões: chmod 600 /etc/kcp/traffic-report.env
#
# ATENÇÃO: nunca commitar este arquivo com valores reais

# ── GitHub ───────────────────────────────────────────────────
# Personal Access Token com permissão: repo (inclui traffic read)
# Criar em: https://github.com/settings/tokens → "Fine-grained tokens"
# Permissões necessárias: Repository > Traffic (read)
GITHUB_TOKEN=ghp_SUBSTITUA_SEU_TOKEN_AQUI
GITHUB_REPO=kcp-protocol/kcp

# ── Email destino ─────────────────────────────────────────────
# Pode ser múltiplos separados por vírgula
REPORT_EMAIL_TO=SEU_EMAIL@AQUI.COM

# ── SMTP (Gmail com App Password) ────────────────────────────
# Para Gmail: ativar 2FA → https://myaccount.google.com/apppasswords
# Criar "App password" para "Mail" → usar a senha de 16 chars abaixo
REPORT_EMAIL_FROM=reports@kcp-protocol.org
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=SEU_GMAIL@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx

# ── Intervalo ─────────────────────────────────────────────────
# Em horas. 1 = a cada hora. 6 = 4x ao dia. 24 = diário
REPORT_INTERVAL_H=1

# ── Peers ─────────────────────────────────────────────────────
PEERS_JSON_URL=https://kcp-protocol.org/peers.json
