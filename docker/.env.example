# KCP Peer Node — Environment Configuration
# Copie para .env e edite antes de rodar docker compose up

# ─── Identidade do peer ───────────────────────────────────────────────────
# ID único do seu peer (sem espaços, sem acentos)
KCP_NODE_ID=my-peer

# E-mail do operador (aparece como user_id dos artefatos publicados pelo peer)
KCP_USER_ID=operator@example.com

# Tenant / organização (use "community" para rede pública)
KCP_TENANT_ID=community

# ─── Rede ─────────────────────────────────────────────────────────────────
# Porta em que o peer vai escutar (externamente)
KCP_PORT=8800

# URL do registro de peers (não altere para entrar na rede pública KCP)
KCP_PEERS_URL=https://kcp-protocol.org/peers.json

# ─── Armazenamento ────────────────────────────────────────────────────────
# Diretório no HOST onde os dados do peer serão persistidos
# Em VPS com volume separado, use o caminho do volume:
#   KCP_DATA_HOST=/dados/kcp-docker/data
KCP_DATA_HOST=./data

# ─── Proxy / SSL (opcional) ───────────────────────────────────────────────
# Necessário apenas se usar: docker compose --profile proxy up -d
# KCP_DOMAIN=mypeer.example.com
# SSL_CERT_PATH=/etc/letsencrypt
